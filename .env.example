# Workspace root (optional)
# Scripts like `pnpm --filter @workspace/scripts seed` load, in order:
#   1) this file when copied to `.env`
#   2) artifacts/api-server/.env
#
# Copy: cp .env.example .env

# Optional: smoke test target for `pnpm verify:api` (must include /api)
# API_VERIFY_BASE_URL=https://skillsnap-ushm.onrender.com/api
# API_VERIFY_BASE_URL=http://localhost:8080/api
