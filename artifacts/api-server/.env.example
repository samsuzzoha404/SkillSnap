# API server (artifacts/api-server)
# Copy to `.env` and fill in. Required for real MongoDB (when USE_MOCK_DATA=false).

PORT=8080

# When USE_MOCK_DATA=false, check DB from the machine running the app:
# GET http://localhost:8080/api/readyz  → { "status":"ok","database":"connected" } or 503

# true = in-memory mock API (no MongoDB). false = MongoDB + real routes.
USE_MOCK_DATA=false

# Required when USE_MOCK_DATA=false (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=YourApp
MONGODB_DB=skillsnap

# Optional: legacy Postgres migration scripts only
DATABASE_URL=

# Optional: JWT signing (defaults to a dev secret if unset — change in production)
# JWT_SECRET=

# Optional: pretty logs in dev (uses pino-pretty worker; can make the process exit on some Windows terminals — prefer default JSON logs)
# PINOTTY=1

# Quieter terminal: disable per-request HTTP logs from pino-http (startup/errors still use logger)
# QUIET_HTTP=1
# (alternative) HTTP_LOG=0

# Optional: reduce all logger output (see src/lib/logger.ts). Default is "info".
# LOG_LEVEL=warn
