{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "kill-port 8080",
    "predev:run": "kill-port 8080",
    "prestart": "kill-port 8080",
    "dev": "cross-env NODE_ENV=development CHOKIDAR_USEPOLLING=1 tsx watch ./src/index.ts",
    "dev:run": "cross-env NODE_ENV=development node --import tsx ./src/index.ts",
    "start": "cross-env NODE_ENV=development node --import tsx ./src/index.ts",
    "dev:pretty": "cross-env NODE_ENV=development PINOTTY=1 CHOKIDAR_USEPOLLING=1 tsx watch ./src/index.ts",
    "build": "tsx ./build.ts",
    "start:prod": "node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.2.2",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "kill-port": "^2.0.1",
    "pino-pretty": "^13",
    "tsx": "catalog:"
  }
}
